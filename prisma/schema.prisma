generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

enum TodoStatus {
  PENDING
  RESOLVED
  COMPLETED
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id                 String        @id @default(cuid())
  username           String        @unique
  passwordHash       String
  role               UserRole      @default(USER)
  isActive           Boolean       @default(true)
  mustChangePassword Boolean       @default(true)
  sessions           Session[]
  todos              Todo[]
  templates          SopTemplate[]
  runs               SopRun[]
  noteFiles          NoteFile[]
  noteImages         NoteImage[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Todo {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  note               String?
  verificationReport String?
  status             TodoStatus   @default(PENDING)
  timePriority       TodoPriority @default(MEDIUM)
  importancePriority TodoPriority @default(MEDIUM)
  dueAt              DateTime?
  completedAt        DateTime?
  runId              String?      @unique
  run                SopRun?      @relation(fields: [runId], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([completedAt])
  @@index([dueAt])
  @@index([userId])
}

model SopTemplate {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  nodes       SopTemplateNode[]
  runs        SopRun[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
}

model SopTemplateNode {
  id          String      @id @default(cuid())
  templateId  String
  template    SopTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int
  isRequired  Boolean     @default(true)
  parentId    String?
  parent      SopTemplateNode?  @relation("TemplateNodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    SopTemplateNode[] @relation("TemplateNodeChildren")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([templateId, sortOrder])
}

model SopRun {
  id                          String       @id @default(cuid())
  userId                      String
  user                        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId                  String
  template                    SopTemplate  @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateNameSnapshot        String
  templateDescriptionSnapshot String?
  title                       String
  version                     String?
  startedAt                   DateTime?
  completedAt                 DateTime?
  archivedAt                  DateTime?
  nodes                       SopRunNode[]
  todo                        Todo?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt

  @@index([completedAt])
  @@index([archivedAt])
  @@index([userId])
}

model SopRunNode {
  id                  String   @id @default(cuid())
  runId               String
  run                  SopRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  nameSnapshot        String
  descriptionSnapshot String?
  note                String?
  sortOrder           Int
  isRequired          Boolean  @default(true)
  parentId            String?
  parent              SopRunNode?  @relation("RunNodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children            SopRunNode[] @relation("RunNodeChildren")
  completedAt         DateTime?
  firstCompletedAt    DateTime?
  lastModifiedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([runId, sortOrder])
}

model NoteImage {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mimeType  String
  extension String
  size      Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model NoteFile {
  id           String   @id
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mimeType     String
  extension    String
  size         Int
  originalName String
  createdAt    DateTime @default(now())

  @@index([userId])
}
